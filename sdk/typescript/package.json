{
  "name": "@vivarium/changeset",
  "version": "0.1.0",
  "description": "Reference TypeScript SDK for the Vivarium Changeset specification — construct, canonicalize, fingerprint, and validate changesets. No apply logic.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=23.6"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "node --test \"src/*.test.ts\"",
    "generate-fixtures": "node tools/generate-fixtures.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
